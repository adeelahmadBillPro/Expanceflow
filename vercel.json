{
  "version": 2,
  "buildCommand": "npm install --prefix client && npm run build --prefix client && npm install --prefix server && cd server && npx prisma generate",
  "outputDirectory": "client/dist",
  "framework": null,
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "server/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/uploads/(.*)", "destination": "/api" },
    { "source": "/((?!api|_next|favicon|manifest|sw|icons).*)", "destination": "/index.html" }
  ]
}
